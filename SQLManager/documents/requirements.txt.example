# Requirements para projeto usando SQLManager
# Repositório privado - requer SSH configurado

# SQLManager - Core (via SSH)
git+ssh://git@github.com/Avalon-Tecnologia/SQLManager.git

# Ou especificar versão/branch:
# git+ssh://git@github.com/Avalon-Tecnologia/SQLManager.git@v4.2.2
# git+ssh://git@github.com/Avalon-Tecnologia/SQLManager.git@main
# git+ssh://git@github.com/Avalon-Tecnologia/SQLManager.git@develop

